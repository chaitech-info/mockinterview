NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: service role key (Supabase → Project Settings → API). Used by /api/paddle/webhook to upsert user_entitlements — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Plan limits (free / 3 interviews / 5 interviews): run SQL in
# supabase/migrations/20260404120000_interview_plans.sql once in the Supabase SQL editor.

# Production: canonical origin (no trailing slash). Used for Google OAuth redirect.
# Example: https://mockinterview.info — set in Vercel; leave unset for local dev.
NEXT_PUBLIC_SITE_URL=

# n8n webhooks (defaults match project; override per environment if needed)
NEXT_PUBLIC_N8N_INTAKE_WEBHOOK_URL=https://n8n.srv851223.hstgr.cloud/webhook-test/intake
NEXT_PUBLIC_N8N_ANSWER_WEBHOOK_URL=https://n8n.srv851223.hstgr.cloud/webhook-test/answer

# Paddle Billing — client-side tokens (Developer tools → Authentication), not the API key.
# Live catalog + live PADDLE_API_KEY → use live client token below.
# Sandbox key (sdbx_) → checkout uses sandbox automatically; set the sandbox client token.
# If checkout shows “Failed to retrieve JWT”, your client token’s mode does not match your API key (live vs sandbox).
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Production checkout reads this first (so CLIENT_TOKEN can stay a sandbox value during testing).
NEXT_PUBLIC_PADDLE_LIVE_CLIENT_TOKEN=
# Optional: sandbox-only client token if you also use NEXT_PUBLIC_PADDLE_CLIENT_TOKEN for live.
NEXT_PUBLIC_PADDLE_SANDBOX_CLIENT_TOKEN=
# Server API key (Dashboard → Developer tools → API keys), not the client-side token.
# Must include permission: Price (Read) / price.read. Product (Read) only if you use include=product.
PADDLE_API_KEY=
# Fallback when the key does not contain sdbx_ or live_: true → sandbox-api.paddle.com
PADDLE_USE_SANDBOX=
# Catalog → Products → Price IDs (e.g. pri_01...) — optional if pricing is loaded from API
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO=
NEXT_PUBLIC_PADDLE_PRICE_ID_TEAMS=

# Webhook: create a notification destination in Paddle (Developer tools → Notifications) pointing to
# https://YOUR_DOMAIN/api/paddle/webhook — subscribe to subscription.* and transaction.completed. Paste the destination secret here.
PADDLE_WEBHOOK_SECRET=
# Production (live) catalog — pri_… from Paddle live dashboard. Used when PADDLE_API_KEY is live_…
# On transaction.completed, PLAN_* also grant +3 / +5 interview credits for initial checkout (not subscription_recurring renewals).
PADDLE_PRICE_ID_PLAN_3=
PADDLE_PRICE_ID_PLAN_5=

# Sandbox / test catalog — pri_… from Paddle sandbox. Used when API key is sdbx_… (or PADDLE_USE_SANDBOX=true).
# If unset in sandbox, code falls back to PADDLE_PRICE_ID_PLAN_* above.
PADDLE_SANDBOX_PRICE_ID_PLAN_3=
PADDLE_SANDBOX_PRICE_ID_PLAN_5=

# Optional: separate one-time credit-pack prices (production).
PADDLE_PRICE_ID_CREDITS_3=
PADDLE_PRICE_ID_CREDITS_5=

# Optional: separate one-time credit-pack prices (sandbox). Falls back to PADDLE_PRICE_ID_CREDITS_* if unset.
PADDLE_SANDBOX_PRICE_ID_CREDITS_3=
PADDLE_SANDBOX_PRICE_ID_CREDITS_5=

