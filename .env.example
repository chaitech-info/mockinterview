NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production: canonical origin (no trailing slash). Used for Google OAuth redirect.
# Example: https://mockinterview.info — set in Vercel; leave unset for local dev.
NEXT_PUBLIC_SITE_URL=

# n8n webhooks (defaults match project; override per environment if needed)
NEXT_PUBLIC_N8N_INTAKE_WEBHOOK_URL=https://n8n.srv851223.hstgr.cloud/webhook-test/intake
NEXT_PUBLIC_N8N_ANSWER_WEBHOOK_URL=https://n8n.srv851223.hstgr.cloud/webhook-test/answer

# Paddle Billing (Dashboard → Developer tools → Authentication: client-side token)
# Environment: production | sandbox
NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Server API key (Dashboard → Developer tools → API keys) — used by /api/paddle/prices to list plans
PADDLE_API_KEY=
# Set to true when using Paddle sandbox (uses sandbox-api.paddle.com)
PADDLE_USE_SANDBOX=
# Catalog → Products → Price IDs (e.g. pri_01...) — optional if pricing is loaded from API
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO=
NEXT_PUBLIC_PADDLE_PRICE_ID_TEAMS=

